# Copia in .env e compila (env della risorsa Coolify). Non committare .env.
# (Il token Cloudflare NON sta qui: vive nell'env del proxy come CF_API_TOKEN,
#  usato dalla label caddy.tls.dns per il certificato wildcard.)

# Dominio dei siti e hosted domain Google ammesso (email).
QUICK_BASE_DOMAIN=quick.example.com
# Domini email Google ammessi all'SSO. Un dominio, una lista "a.com,b.com",
# oppure "*" (o vuoto) per qualsiasi account. Vale sia per quick-server che per
# oauth2-proxy (OAUTH2_PROXY_EMAIL_DOMAINS).
QUICK_ALLOWED_DOMAIN=example.com

# Client OAuth Google della CLI. Due modi:
#  - client "Desktop app" (PKCE, nessun secret): imposta solo QUICK_CLI_CLIENT_ID.
#  - riuso di un client "Web" (anche lo stesso di oauth2-proxy): imposta entrambi;
#    il secret viene servito alla CLI via /api/config.
# Redirect URI autorizzato sul client: http://127.0.0.1:8765/callback
QUICK_CLI_CLIENT_ID=
QUICK_CLI_CLIENT_SECRET=

# Client OAuth Google di oauth2-proxy: tipo "Web application".
# Redirect URI autorizzato: https://auth.<QUICK_BASE_DOMAIN>/oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Segreto cookie di oauth2-proxy.            openssl rand -base64 32
COOKIE_SECRET=
# Segreto con cui quick-server firma codici e cookie dei siti privati.
QUICK_META_SECRET=

# Storage: local (default) | s3
QUICK_STORAGE=local
# Se QUICK_STORAGE=s3 (object storage S3-compatibile: Hetzner/MinIO/R2/…):
QUICK_S3_ENDPOINT=
QUICK_S3_REGION=
QUICK_S3_BUCKET=
QUICK_S3_ACCESS_KEY=
QUICK_S3_SECRET_KEY=
QUICK_S3_PREFIX=
QUICK_S3_USE_SSL=true
